{
  "name": "vulor-frontend",
  "version": "1.0.0",
  "description": "Tailwind CSS v4 build pipeline for VULOR's Django templates.",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./frontend/static_src/css/style.css -o ./frontend/static/css/dist/style.css --minify",
    "watch:css": "tailwindcss -i ./frontend/static_src/css/style.css -o ./frontend/static/css/dist/style.css --watch",
    "build": "npm run build:css"
  },
  "license": "UNLICENSED",
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.17",
    "tailwindcss": "^4.1.17"
  }
}
