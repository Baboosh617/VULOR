# Django
DEBUG=True
SECRET_KEY=generate-a-long-random-key-here

# Database (App Platform injects DATABASE_URL automatically from managed DB)
DATABASE_URL=sqlite:///db.sqlite3

# App Platform sets PORT automatically — leave this commented locally
# PORT=8080

# Hosts / CSRF
ALLOWED_HOSTS=.example.com,www.example.com
CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
SITE_URL=https://example.com

# Paystack (test keys for development — use live keys in production)
PAYSTACK_PUBLIC_KEY=pk_test_xxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxx
# PAYSTACK_WEBHOOK_SECRET=whsec_xxxxx

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Fallback key name (used in legacy environments):
# GOOGLE_SECRET_KEY=

# SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=you@example.com
EMAIL_HOST_PASSWORD=your_app_password
# Must be a sender address your SMTP provider has verified —
# this is the From on every customer email (verification, receipts)
DEFAULT_FROM_EMAIL=VULOR <you@example.com>
ADMIN_EMAIL=you@example.com

# Celery / async (requires REDIS_URL and a worker service)
EMAIL_ASYNC_ENABLED=False
REDIS_URL=

# Media (App Platform: /var/data persists across deploys)
MEDIA_ROOT=/var/data/media

# Bank-transfer payment instructions
BANK_TRANSFER_BANK_NAME=Example Bank
BANK_TRANSFER_ACCOUNT_NAME=VULOR Store
BANK_TRANSFER_ACCOUNT_NUMBER=0123456789

# Admin URL prefix (default: admin/)
# ADMIN_URL=secret-admin/
