DEBUG=True
SECRET_KEY=your-django-secret-here
DATABASE_URL=sqlite:///db.sqlite3
BANK_TRANSFER_BANK_NAME=Example Bank
BANK_TRANSFER_ACCOUNT_NAME=VULOR Store
BANK_TRANSFER_ACCOUNT_NUMBER=0123456789
SITE_URL=http://127.0.0.1:8000
EMAIL_HOST=smtp.example.com
# Standard TLS submission port — Brevo/most relays use 587
EMAIL_PORT=587
EMAIL_HOST_USER=you@example.com
EMAIL_HOST_PASSWORD=your_email_password
# Must be a sender address your SMTP provider has verified —
# this is the From on every customer email (verification, receipts)
DEFAULT_FROM_EMAIL=store@example.com
# Set to True only where a Celery worker and Redis broker are running
EMAIL_ASYNC_ENABLED=False
